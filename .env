# Dokter Pool CMS Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=development

# Site URL (for sitemap, OG tags, canonical URLs)
SITE_URL=https://dokterpool.com

# Session Secret (change this in production)
SESSION_SECRET=dokterpool-secret-key-2024-change-in-production

# Admin Credentials (default - change after first login)
# Username: admin
# Password: admin123

# WhatsApp Number (with country code, no + or spaces)
WHATSAPP_NUMBER=6281234567890

# Company Info (also editable in admin dashboard)
COMPANY_NAME=Dokter Pool
COMPANY_PHONE=+62 21 1234 5678
COMPANY_EMAIL=info@dokterpool.com
COMPANY_ADDRESS=Jl. Sudirman No. 123, Jakarta